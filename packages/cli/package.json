{
  "name": "@specord/cli",
  "version": "0.1.0",
  "description": "CLI entrypoint for Specord",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "specord": "./bin/specord.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@specord/core": "workspace:*",
    "@specord/openapi": "workspace:*",
    "@specord/ui": "workspace:*",
    "@specord/types": "workspace:*"
  }
}
