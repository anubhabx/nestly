{
  "name": "@specord/nestjs",
  "version": "0.1.0",
  "description": "NestJS adapter for Specord",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anubhabx/specord.git",
    "directory": "packages/nestjs"
  },
  "bugs": {
    "url": "https://github.com/anubhabx/specord/issues"
  },
  "homepage": "https://github.com/anubhabx/specord#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@specord/core": "workspace:*",
    "@specord/openapi": "workspace:*",
    "@specord/ui": "workspace:*",
    "@specord/types": "workspace:*"
  }
}
